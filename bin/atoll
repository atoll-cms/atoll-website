#!/usr/bin/env php
<?php

declare(strict_types=1);

$projectRoot = dirname(__DIR__);
$corePath = atollLauncherResolveCorePath($projectRoot);
$bootstrap = $corePath . '/src/bootstrap.php';

if (!is_file($bootstrap)) {
    fwrite(STDERR, "atoll: core bootstrap not found at {$bootstrap}\n");
    exit(1);
}

require $bootstrap;

if (!class_exists(\Atoll\Cli\Application::class)) {
    fwrite(STDERR, "atoll: core CLI application is unavailable (Atoll\\Cli\\Application not found).\n");
    exit(1);
}

\Atoll\Cli\Application::run($argv, $projectRoot);

function atollLauncherResolveCorePath(string $projectRoot): string
{
    $configured = atollLauncherReadConfiguredCorePath($projectRoot . '/config.yaml') ?? 'core';
    $candidate = atollLauncherNormalizePath($projectRoot, $configured);

    if (is_file($candidate . '/src/bootstrap.php')) {
        return $candidate;
    }

    $fallback = rtrim($projectRoot . '/core', '/');
    if (is_file($fallback . '/src/bootstrap.php')) {
        return $fallback;
    }

    return $candidate;
}

function atollLauncherReadConfiguredCorePath(string $configPath): ?string
{
    if (!is_file($configPath)) {
        return null;
    }

    $raw = file_get_contents($configPath);
    if (!is_string($raw) || trim($raw) === '') {
        return null;
    }

    if (!preg_match('/^core:\s*$\R(?P<body>(?:[ \t].*\R?)*)/m', $raw, $match)) {
        return null;
    }

    $body = $match['body'] ?? '';
    if (!preg_match('/^\s*path:\s*(.+?)\s*$/m', $body, $pathMatch)) {
        return null;
    }

    $value = trim((string) ($pathMatch[1] ?? ''));
    if ($value === '') {
        return null;
    }

    $value = preg_replace('/\s+#.*$/', '', $value) ?? $value;
    $value = trim($value, " \t\"'");

    return $value !== '' ? $value : null;
}

function atollLauncherNormalizePath(string $projectRoot, string $path): string
{
    $path = trim($path);
    if ($path === '') {
        return rtrim($projectRoot . '/core', '/');
    }

    if ($path[0] === '/' || preg_match('~^[A-Za-z]:[\\\\/]~', $path) === 1) {
        return rtrim($path, '/');
    }

    return rtrim($projectRoot . '/' . ltrim($path, '/'), '/');
}
