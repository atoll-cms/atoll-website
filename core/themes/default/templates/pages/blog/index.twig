{% extends 'layouts/base.twig' %}

{% block content %}
  <h1>Blog</h1>
  <div class="post-list">
    {% for item in items %}
      <article class="post-card">
        <h2><a href="{{ url(item.url) }}">{{ item.title }}</a></h2>
        <p class="meta">{{ item.date }} · {{ item.author|default('Admin') }}</p>
        <p>{{ item.excerpt }}</p>
      </article>
    {% else %}
      <p>Noch keine Beitraege vorhanden.</p>
    {% endfor %}
  </div>
{% endblock %}
